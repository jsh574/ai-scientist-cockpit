{
  "name": "ai-scientist-cockpit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "EurekaLoop conversation-first multi-agent AI Scientist frontend.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:backend": "python -m uvicorn backend.app.main:app --host 127.0.0.1 --port 8000",
    "typecheck": "tsc --noEmit",
    "test:backend": "python -m unittest discover -s backend/tests -v",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
