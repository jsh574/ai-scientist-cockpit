# Keep real credentials in backend/.env. Never commit that file.
DASHSCOPE_API_KEY=
QWEN_API_KEY=
LLM_API_KEY=
QWEN_MODEL=qwen3.7-max
LLM_MODEL=qwen3.7-max
DASHSCOPE_BASE_URL=https://ws-7hqgj5wzj4r60zy7.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://ws-7hqgj5wzj4r60zy7.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=0
LLM_MAX_TOKENS=8192
QWEN_ENABLE_THINKING=false
KNOWLEDGE_LLM_MAX_ATTEMPTS=1
KNOWLEDGE_MAX_QUERIES=3
KNOWLEDGE_MAX_PAPERS=12
KNOWLEDGE_PER_CLIENT_LIMIT=2
HYPOTHESIS_MIN_EVIDENCE_OVERLAP=0
HYPOTHESIS_MAX_RETRIES=1
EVIDENCE_MAPPING_THRESHOLD=7.0
EVIDENCE_MAPPING_MODE=auto
PLANNING_MAX_HYPOTHESES=2
PLANNING_MAX_PARALLEL_CALLS=1
PLANNING_MAX_REVISIONS=1
DIFY_API_URL=https://your-dify-host.example.com
DIFY_API_KEY=
DIFY_USER=research-planning-agent
DIFY_RESPONSE_MODE=streaming
DIFY_TIMEOUT_SECONDS=300
DIFY_SHOW_PROGRESS=0
DIFY_MAX_PARALLEL_CALLS=1

# Planning Agent A -> B -> C production configuration.
# Each published Dify Workflow is a separate App and therefore needs its own API key.
# Workflow URLs fall back to DIFY_API_URL when left empty. Workflow C's key falls
# back to DIFY_API_KEY, preserving the current single-workflow deployment.
DIFY_WORKFLOW_A_API_URL=
DIFY_WORKFLOW_A_API_KEY=
DIFY_WORKFLOW_B_API_URL=
DIFY_WORKFLOW_B_API_KEY=
DIFY_WORKFLOW_C_API_URL=
DIFY_WORKFLOW_C_API_KEY=
DIFY_CHAIN_USER=research-planning-agent
DIFY_CHAIN_RESPONSE_MODE=streaming
DIFY_CHAIN_TIMEOUT_SECONDS=300
DIFY_WORKFLOW_B_MAX_FORMAT_RETRIES=1
DIFY_WORKFLOW_C_PLANNING_CONSTRAINTS_MAX_CHARS=12000

REVIEW_GATE_THRESHOLD=0.75
MAX_WORKFLOW_ITERATIONS=10
ARTIFACTS_ROOT=artifacts/tasks
MCP_TRANSPORT=stdio
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Paths are relative to the repository root. Override only for standalone Agent debugging.
AGENTS_ROOT=agents
PROBLEM_AGENT_ROOT=agents/problem_understanding
KNOWLEDGE_AGENT_ROOT=agents/knowledge_integration
HYPOTHESIS_AGENT_FILE=agents/hypothesis_generation/hypothesis_generation_agent.py
EVIDENCE_AGENT_ROOT=agents/evidence_mapping
PLANNING_AGENT_ROOT=agents/planning
