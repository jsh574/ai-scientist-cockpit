# Dify host shared by Workflow A/B/C. Do not append /v1/workflows/run unless desired.
DIFY_API_URL=https://your-dify-host.example.com

# Every published Dify Workflow app has its own API key.
DIFY_WORKFLOW_A_API_KEY=
DIFY_WORKFLOW_B_API_KEY=
DIFY_WORKFLOW_C_API_KEY=

# Optional per-workflow host overrides.
DIFY_WORKFLOW_A_API_URL=
DIFY_WORKFLOW_B_API_URL=
DIFY_WORKFLOW_C_API_URL=

DIFY_CHAIN_USER=research-planning-agent-chain-test
DIFY_CHAIN_RESPONSE_MODE=streaming
DIFY_CHAIN_TIMEOUT_SECONDS=300
# Extra Workflow B attempts after a malformed structured-output guard failure (0-2).
DIFY_WORKFLOW_B_MAX_FORMAT_RETRIES=1
DIFY_WORKFLOW_C_PLANNING_CONSTRAINTS_MAX_CHARS=12000

# Shared generic transport fallbacks used by all three Workflow clients.
DIFY_RESPONSE_MODE=streaming
DIFY_TIMEOUT_SECONDS=300
DIFY_SHOW_PROGRESS=1
PLANNING_MAX_PARALLEL_CALLS=1
