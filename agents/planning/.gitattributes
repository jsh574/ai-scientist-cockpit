# Normalize text files across Windows/Linux/macOS.
* text=auto eol=lf

# Source and config files.
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.env text eol=lf
*.example text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf

# Binary files.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
