{
  "schema_version": "agent_manifest_v1",
  "protocol_version": "1.1",
  "response_schema": "../schemas/agent_response.schema.json",
  "stages": [
    {
      "stage": "question_understanding",
      "agent_id": "question_understanding_agent",
      "display_name": {"zh": "问题理解", "en": "Question Understanding"},
      "aliases": ["@question", "@understanding", "@question_understanding", "@问题理解", "@理解"],
      "entrypoint": "problem_understanding.problem_understanding.agent:ProblemUnderstandingAgent",
      "schema_version": "node_spec_v1",
      "reads": ["task_id", "iteration", "user_input"],
      "writes": ["question_card"],
      "interruptible": false,
      "hybrid_review": false,
      "retry_policy": {"max_attempts": 1, "backoff_seconds": 0, "retry_on": ["review_gate_retry"]},
      "progress_nodes": ["question_parse", "scope_normalize", "question_card_build"],
      "description": "Normalize a scientific question into a testable question card."
    },
    {
      "stage": "knowledge_integration",
      "agent_id": "knowledge_integration_agent",
      "display_name": {"zh": "知识整合", "en": "Knowledge Integration"},
      "aliases": ["@knowledge", "@knowledge_integration", "@literature", "@文献", "@知识整合"],
      "entrypoint": "knowledge_integration.knowledge_integration_agent:KnowledgeIntegrationAgent",
      "schema_version": "node_spec_v1",
      "reads": ["task_id", "iteration", "question_card", "user_input"],
      "writes": ["literature_cards", "evidence_cards", "knowledge_gaps"],
      "interruptible": false,
      "hybrid_review": false,
      "retry_policy": {"max_attempts": 1, "backoff_seconds": 0, "retry_on": ["review_gate_retry"]},
      "progress_nodes": ["literature_search", "evidence_integration", "knowledge_gap_synthesis"],
      "description": "Retrieve and structure traceable literature and evidence."
    },
    {
      "stage": "hypothesis_generation",
      "agent_id": "hypothesis_generation_agent",
      "display_name": {"zh": "假设生成", "en": "Hypothesis Generation"},
      "aliases": ["@hypothesis", "@hypothesis_generation", "@假设", "@假设生成"],
      "entrypoint": "hypothesis_generation.hypothesis_generation_agent:HypothesisGenerationAgent",
      "schema_version": "node_spec_v1",
      "reads": ["task_id", "iteration", "question_card", "evidence_cards", "knowledge_gaps", "user_input"],
      "writes": ["hypothesis_cards"],
      "interruptible": false,
      "hybrid_review": false,
      "retry_policy": {"max_attempts": 1, "backoff_seconds": 0, "retry_on": ["review_gate_retry"]},
      "progress_nodes": ["hypothesis_draft", "evidence_binding", "gap_binding", "quality_review"],
      "description": "Generate evidence-bound and falsifiable hypotheses."
    },
    {
      "stage": "evidence_mapping",
      "agent_id": "evidence_mapping_agent",
      "display_name": {"zh": "证据梳理", "en": "Evidence Mapping"},
      "aliases": ["@evidence", "@evidence_mapping", "@证据", "@证据梳理"],
      "entrypoint": "evidence_mapping.src.evidence_mapping:EvidenceMappingAgent",
      "schema_version": "node_spec_v1",
      "reads": ["task_id", "iteration", "hypothesis_cards", "evidence_cards", "literature_cards"],
      "writes": ["evidence_map"],
      "interruptible": false,
      "hybrid_review": true,
      "retry_policy": {"max_attempts": 1, "backoff_seconds": 0, "retry_on": ["review_gate_retry"]},
      "progress_nodes": ["candidate_select", "support_map", "opposition_map", "score_review"],
      "description": "Bind hypotheses to supporting, opposing, and uncertain evidence."
    },
    {
      "stage": "research_planning",
      "agent_id": "research_planning_agent",
      "display_name": {"zh": "研究规划", "en": "Research Planning"},
      "aliases": ["@plan", "@planning", "@research_planning", "@计划", "@研究规划"],
      "entrypoint": "planning.planning_agent.service:run_planning_agent",
      "schema_version": "node_spec_v1",
      "reads": ["task_id", "iteration", "question_card", "hypothesis_cards", "evidence_map", "evidence_cards", "literature_cards", "knowledge_gaps", "user_input"],
      "writes": ["research_plan"],
      "interruptible": false,
      "hybrid_review": true,
      "retry_policy": {"max_attempts": 1, "backoff_seconds": 0, "retry_on": ["review_gate_retry"]},
      "progress_nodes": ["package_normalize", "method_design", "dataset_design", "reference_trace"],
      "description": "Produce an executable plan with metrics and falsification criteria."
    },
    {
      "stage": "final_review",
      "agent_id": "orchestrator_review_gate",
      "display_name": {"zh": "最终总评", "en": "Final Review"},
      "aliases": ["@final", "@review", "@final_review", "@总评", "@最终输出"],
      "entrypoint": "backend.app.review_gate:ReviewGate",
      "schema_version": "node_spec_v1",
      "reads": ["task_id", "iteration", "question_card", "literature_cards", "evidence_cards", "knowledge_gaps", "hypothesis_cards", "evidence_map", "research_plan", "reviews", "versions", "feedback_events"],
      "writes": ["final_review"],
      "interruptible": false,
      "hybrid_review": true,
      "retry_policy": {"max_attempts": 1, "backoff_seconds": 0, "retry_on": ["review_gate_retry"]},
      "progress_nodes": ["traceability_audit", "quality_score", "iteration_decision"],
      "description": "Audit completeness, traceability, and iteration readiness."
    }
  ]
}
